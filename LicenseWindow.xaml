<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VedionScreenShare.LicenseWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vedion Screen Share — Activate"
    Height="280" Width="500"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#F5F5F5">

    <DockPanel Margin="30">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
            <Button x:Name="ActivateButton" Content="Activate" Padding="16,8"
                    Background="#28a745" Foreground="White" FontWeight="Bold"
                    Click="ActivateButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="BuyButton" Content="Buy a License" Padding="16,8"
                    Background="#007ACC" Foreground="White"
                    Click="BuyButton_Click"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Vedion Screen Share" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Enter your license key to activate." FontSize="12" Foreground="#666" Margin="0,0,0,20"/>

            <TextBlock Text="License Key:" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="LicenseKeyInput" Height="36" Padding="10,8"
                     FontSize="12" FontFamily="Consolas"
                     Background="White" BorderBrush="#ccc"
                     Text="" MaxLength="40"/>

            <TextBlock x:Name="StatusLabel" Text="" Margin="0,10,0,0"
                       FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
        </StackPanel>

    </DockPanel>
</Window>
