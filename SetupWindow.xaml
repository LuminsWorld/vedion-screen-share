<?xml version="1.0" encoding="utf-8"?>
<Window 
    x:Class="VedionScreenShare.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vedion Screen Share - Setup"
    Height="500"
    Width="600"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#F5F5F5">
    
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Top" Spacing="20">
            
            <!-- Header -->
            <StackPanel>
                <TextBlock 
                    Text="Vedion Screen Share Setup"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="#1a1a1a"
                    Margin="0,0,0,10"/>
                <TextBlock 
                    Text="This application will record your screen and send encrypted frames for live assistance."
                    FontSize="12"
                    Foreground="#666"
                    TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Disclosure -->
            <Border BorderBrush="#ddd" BorderThickness="1" Background="#fff9e6" Padding="15" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="⚠️ What This Does" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock 
                        Text="✓ Records your screen at regular intervals&#x0a;✓ Encrypts all frames with AES-256&#x0a;✓ Sends encrypted data to the configured endpoint&#x0a;✓ Runs in the background with minimal interference&#x0a;✓ Shows status in system tray"
                        FontSize="11"
                        Foreground="#333"
                        TextWrapping="Wrap"
                        LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- Configuration -->
            <StackPanel Spacing="12">
                
                <!-- Endpoint -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Endpoint URL (WebSocket)" FontWeight="SemiBold"/>
                    <TextBox 
                        x:Name="EndpointInput"
                        Height="32"
                        Padding="8"
                        FontSize="11"
                        Text="wss://vedion.example.com/screen"
                        Background="White"
                        BorderBrush="#ccc"/>
                </StackPanel>

                <!-- Encryption Key -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Encryption Key (Base64)" FontWeight="SemiBold"/>
                        <Button 
                            x:Name="GenerateKeyButton"
                            Content="Generate New"
                            Padding="8,4"
                            FontSize="10"
                            Background="#007ACC"
                            Foreground="White"
                            Click="GenerateKeyButton_Click"/>
                    </StackPanel>
                    <TextBox 
                        x:Name="KeyInput"
                        Height="32"
                        Padding="8"
                        FontSize="10"
                        Background="White"
                        BorderBrush="#ccc"
                        TextWrapping="Wrap"
                        AcceptsReturn="False"/>
                </StackPanel>

                <!-- Capture Interval -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Capture Interval (ms):" FontWeight="SemiBold"/>
                        <TextBlock x:Name="IntervalLabel" Text="1000" Foreground="#666"/>
                    </StackPanel>
                    <Slider 
                        x:Name="IntervalSlider"
                        Minimum="500"
                        Maximum="5000"
                        Value="1000"
                        TickFrequency="500"
                        IsSnapToTickEnabled="True"
                        Height="20"/>
                </StackPanel>

                <!-- JPEG Quality -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Image Quality:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="QualityLabel" Text="75%" Foreground="#666"/>
                    </StackPanel>
                    <Slider 
                        x:Name="QualitySlider"
                        Minimum="40"
                        Maximum="95"
                        Value="75"
                        TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        Height="20"/>
                </StackPanel>

            </StackPanel>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel 
            VerticalAlignment="Bottom"
            Orientation="Horizontal"
            Spacing="10">
            <Button 
                x:Name="CancelButton"
                Content="Cancel"
                Padding="16,8"
                Background="#f0f0f0"
                Foreground="#1a1a1a"
                BorderBrush="#ccc"
                Click="CancelButton_Click"/>
            <Button 
                x:Name="StartButton"
                Content="Start Sharing"
                Padding="16,8"
                Background="#28a745"
                Foreground="White"
                FontWeight="Bold"
                Click="StartButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
