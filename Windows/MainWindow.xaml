<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VedionScreenShare.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vedion Screen Share"
    Width="560" Height="680"
    MinWidth="480" MinHeight="580"
    WindowStartupLocation="CenterScreen"
    Background="#0a0a0a"
    Foreground="#f0f0f0"
    FontFamily="Segoe UI"
    Closing="Window_Closing">

    <Window.Resources>
        <!-- Text styles -->
        <Style x:Key="MonoLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="LetterSpacing" Value="2"/>
        </Style>

        <!-- Input -->
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="#f0f0f0"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#00FF41"/>
        </Style>
        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="#f0f0f0"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Mode tab button -->
        <Style x:Key="ModeTab" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2a2a2a"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#00FF41"/>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#00cc33"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#1a1a1a"/><Setter Property="Foreground" Value="#444"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small ghost button -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#00FF41"/>
                                <Setter Property="Foreground" Value="#00FF41"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle / CheckBox -->
        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="#f0f0f0"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <!-- Slider -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#00FF41"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── TOP BAR ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#0f0f0f" BorderBrush="#1a1a1a" BorderThickness="0,0,0,1" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0" Text="VEDION" FontFamily="Consolas" FontSize="11" Foreground="#00FF41" VerticalAlignment="Center" Margin="0,0,24,0"/>

                <!-- Mode tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="TabDiscord"  Content="DISCORD"     Style="{StaticResource ModeTab}" Click="TabDiscord_Click"/>
                    <Button x:Name="TabAi"       Content="AI ANALYSIS" Style="{StaticResource ModeTab}" Click="TabAi_Click"/>
                </StackPanel>

                <!-- User info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel" Text="" FontFamily="Consolas" FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="SignOutBtn" Content="SIGN OUT" Style="{StaticResource GhostBtn}" Click="SignOut_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── STATUS BAR ────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="#0f0f0f" BorderBrush="#1a1a1a" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0" FontFamily="Consolas" FontSize="10" Foreground="#555" VerticalAlignment="Center" Text="Ready"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="HotkeyLabel" FontFamily="Consolas" FontSize="10" Foreground="#333" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <Button Content="MINIMIZE TO TRAY" Style="{StaticResource GhostBtn}" Click="MinimizeToTray_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── SHARED SETTINGS (always visible) ─────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="#0f0f0f" BorderBrush="#1a1a1a" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Region -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="CAPTURE REGION" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RegionBtn" Content="SELECT REGION" Style="{StaticResource GhostBtn}" Click="SelectRegion_Click" Margin="0,0,8,0"/>
                        <Button Content="RESET" Style="{StaticResource GhostBtn}" Click="ResetRegion_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="RegionLabel" Text="Full screen" FontFamily="Consolas" FontSize="10" Foreground="#444" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Quality -->
                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="JPEG QUALITY" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <Slider x:Name="QualitySlider" Minimum="20" Maximum="95" Value="60" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="QualitySlider_Changed"/>
                    <TextBlock x:Name="QualityLabel" Text="60%" FontFamily="Consolas" FontSize="10" Foreground="#444" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Hotkey display -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="SNAPSHOT HOTKEY" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="SnapHotkeyDisplay" Text="Ctrl+Shift+S" FontFamily="Consolas" FontSize="11" Foreground="#555"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── MAIN CONTENT AREA ─────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,20,20,0">
            <StackPanel>

                <!-- ═══ DISCORD MODE ════════════════════════════════════════ -->
                <StackPanel x:Name="DiscordPanel">

                    <TextBlock Text="DISCORD SNAPSHOT" FontFamily="Consolas" FontSize="10" Foreground="#00FF41" Margin="0,0,0,4"/>
                    <TextBlock Text="Press the hotkey to capture and send a frame to your Discord channel." FontSize="12" Foreground="#555" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <!-- Webhook URL -->
                    <TextBlock Text="WEBHOOK URL" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="DiscordWebhookInput" Grid.Column="0" Style="{StaticResource Field}" Margin="0,0,8,0"
                                 ToolTip="Paste your Discord webhook URL here"/>
                        <Button Grid.Column="1" Content="TEST" Style="{StaticResource GhostBtn}" Click="TestDiscordWebhook_Click"/>
                    </Grid>

                    <!-- Include image toggle -->
                    <CheckBox x:Name="DiscordImageToggle" Style="{StaticResource Toggle}" Content="Include screenshot in Discord post" Margin="0,0,0,24"/>

                    <!-- Last sent info -->
                    <Border Background="#111" BorderBrush="#1a1a1a" BorderThickness="1" CornerRadius="6" Padding="16">
                        <StackPanel>
                            <TextBlock Text="ACTIVITY" FontFamily="Consolas" FontSize="10" Foreground="#333" Margin="0,0,0,10"/>
                            <TextBlock x:Name="DiscordLastSent" Text="No snapshots sent yet." FontSize="12" Foreground="#555"/>
                            <TextBlock x:Name="DiscordSentCount" Text="Total sent: 0" FontFamily="Consolas" FontSize="10" Foreground="#333" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- How-to reminder -->
                    <Border Background="#0d1a0d" BorderBrush="#1a2a1a" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="HOW TO USE" FontFamily="Consolas" FontSize="10" Foreground="#2a4a2a" Margin="0,0,0,8"/>
                            <TextBlock FontSize="12" Foreground="#3a6a3a" TextWrapping="Wrap">
                                1. Paste your Discord webhook URL above<LineBreak/>
                                2. Select a region (optional — default is full screen)<LineBreak/>
                                3. Press <Run FontWeight="Bold" Foreground="#00FF41">Ctrl+Shift+S</Run> any time to send a snapshot
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ AI MODE ══════════════════════════════════════════════ -->
                <StackPanel x:Name="AiPanel" Visibility="Collapsed">

                    <TextBlock Text="AI ANALYSIS" FontFamily="Consolas" FontSize="10" Foreground="#7B2FFF" Margin="0,0,0,4"/>
                    <TextBlock Text="Send a screenshot to any AI. Response posts to Discord." FontSize="12" Foreground="#555" Margin="0,0,0,20" TextWrapping="Wrap"/>

                    <!-- AI Provider -->
                    <TextBlock Text="AI PROVIDER" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                    <ComboBox x:Name="AiProviderCombo" Margin="0,0,0,16" SelectionChanged="AiProviderCombo_Changed"/>

                    <!-- API Key -->
                    <TextBlock Text="API KEY" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="AiKeyInput" Style="{StaticResource PasswordField}" Margin="0,0,0,16"/>

                    <!-- Model -->
                    <TextBlock Text="MODEL" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                    <TextBox x:Name="AiModelInput" Style="{StaticResource Field}" Margin="0,0,0,16"/>

                    <!-- Custom endpoint (shown for Custom provider) -->
                    <StackPanel x:Name="CustomEndpointPanel" Visibility="Collapsed">
                        <TextBlock Text="ENDPOINT URL" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                        <TextBox x:Name="AiEndpointInput" Style="{StaticResource Field}" Margin="0,0,0,16"
                                 ToolTip="OpenAI-compatible endpoint (e.g. https://api.openai.com/v1/chat/completions)"/>
                    </StackPanel>

                    <!-- Prompt -->
                    <TextBlock Text="PROMPT" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                    <TextBox x:Name="AiPromptInput" Style="{StaticResource Field}" Height="72" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"
                             Text="Describe what you see on this screen. Be concise and helpful."/>

                    <!-- Output webhook -->
                    <TextBlock Text="OUTPUT DISCORD WEBHOOK" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="AiWebhookInput" Grid.Column="0" Style="{StaticResource Field}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="TEST" Style="{StaticResource GhostBtn}" Click="TestAiWebhook_Click"/>
                    </Grid>

                    <!-- Include image toggle -->
                    <CheckBox x:Name="AiImageToggle" Style="{StaticResource Toggle}" Content="Include screenshot in Discord post" Margin="0,0,0,16"/>

                    <!-- Trigger mode -->
                    <TextBlock Text="TRIGGER" FontFamily="Consolas" FontSize="10" Foreground="#555" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="HotkeyRadio" Content="Hotkey (Ctrl+Shift+S)" Foreground="#888" FontSize="12"
                                     GroupName="TriggerMode" IsChecked="True" Margin="0,0,16,0" Checked="TriggerMode_Changed"/>
                        <RadioButton x:Name="IntervalRadio" Content="Interval" Foreground="#888" FontSize="12"
                                     GroupName="TriggerMode" Checked="TriggerMode_Changed"/>
                    </StackPanel>

                    <!-- Interval controls -->
                    <StackPanel x:Name="IntervalPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Slider x:Name="AiIntervalSlider" Grid.Column="0" Minimum="5" Maximum="300" Value="10"
                                    TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="IntervalSlider_Changed" Margin="0,0,12,0"/>
                            <TextBlock x:Name="IntervalLabel" Grid.Column="1" Text="10s" FontFamily="Consolas" FontSize="11" Foreground="#555" VerticalAlignment="Center" Width="36"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="StartIntervalBtn" Content="START" Style="{StaticResource ActionBtn}" Click="StartInterval_Click" Margin="0,0,8,0"/>
                            <Button x:Name="StopIntervalBtn" Content="STOP" Style="{StaticResource GhostBtn}" Click="StopInterval_Click" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Test button (hotkey mode) -->
                    <Button x:Name="AiTestBtn" Content="TEST NOW" Style="{StaticResource GhostBtn}" Click="AiTestNow_Click" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                    <!-- Last AI response -->
                    <Border Background="#111" BorderBrush="#1a1a1a" BorderThickness="1" CornerRadius="6" Padding="16">
                        <StackPanel>
                            <TextBlock Text="LAST RESPONSE" FontFamily="Consolas" FontSize="10" Foreground="#333" Margin="0,0,0,10"/>
                            <TextBlock x:Name="AiLastResponse" Text="No analysis yet." FontSize="12" Foreground="#555" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
