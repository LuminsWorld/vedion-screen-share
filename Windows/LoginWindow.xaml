<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VedionScreenShare.Windows.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vedion Screen Share"
    Width="420" Height="600"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent">

  <Window.Effect>
    <DropShadowEffect BlurRadius="32" ShadowDepth="8" Direction="270" Opacity="0.6" Color="#000000"/>
  </Window.Effect>

  <Border Background="#0a0a0a" CornerRadius="12" BorderBrush="#1e1e1e" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>   <!-- drag bar -->
        <RowDefinition/>
      </Grid.RowDefinitions>

      <!-- Drag bar -->
      <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="#0f0f0f"
              MouseLeftButtonDown="DragBar_MouseDown">
        <Grid Margin="20,0">
          <TextBlock Text="VEDION SCREEN SHARE" FontFamily="Consolas" FontSize="10"
                     Foreground="#2a2a2a" VerticalAlignment="Center"/>
          <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                  FontSize="12" Foreground="#444" Background="Transparent" BorderThickness="0"
                  Cursor="Hand" Click="CloseBtn_Click"
                  Width="28" Height="28">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#3a0000"/>
                    <Setter Property="Foreground" Value="#f87171"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </Grid>
      </Border>

      <!-- Content -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="36,0,36,36">
        <StackPanel>

          <!-- Logo area -->
          <Grid Margin="0,28,0,32">
            <StackPanel HorizontalAlignment="Center">
              <!-- Green accent bar -->
              <Border Width="40" Height="3" Background="#00FF41" CornerRadius="2" HorizontalAlignment="Center" Margin="0,0,0,16"/>
              <TextBlock x:Name="TitleLabel" Text="Sign in" FontSize="28" FontWeight="Black"
                         Foreground="#f0f0f0" HorizontalAlignment="Center" Margin="0,0,0,6"/>
              <TextBlock x:Name="SubLabel" Text="Access your Vedion Screen Share license."
                         FontSize="12" Foreground="#555" HorizontalAlignment="Center"
                         TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>

          <!-- Status -->
          <Border x:Name="StatusBorder" Background="#1a0a0a" BorderBrush="#3a1a1a"
                  BorderThickness="1" CornerRadius="6" Padding="12,10"
                  Margin="0,0,0,16" Visibility="Collapsed">
            <TextBlock x:Name="StatusLabel" FontSize="12" Foreground="#f87171" TextWrapping="Wrap"/>
          </Border>

          <!-- Display name (sign-up) -->
          <StackPanel x:Name="NamePanel" Visibility="Collapsed" Margin="0,0,0,16">
            <TextBlock Text="DISPLAY NAME" Style="{StaticResource MonoLabel}"/>
            <TextBox x:Name="NameInput" Style="{StaticResource Field}"/>
          </StackPanel>

          <!-- Email -->
          <TextBlock Text="EMAIL" Style="{StaticResource MonoLabel}"/>
          <TextBox x:Name="EmailInput" Style="{StaticResource Field}" Margin="0,0,0,16"/>

          <!-- Password -->
          <TextBlock Text="PASSWORD" Style="{StaticResource MonoLabel}"/>
          <PasswordBox x:Name="PasswordInput" Style="{StaticResource PasswordField}"
                       Margin="0,0,0,6" KeyDown="PasswordInput_KeyDown"/>

          <!-- Forgot -->
          <TextBlock x:Name="ForgotLink" Text="Forgot password?" FontSize="11" Foreground="#444"
                     Cursor="Hand" HorizontalAlignment="Right" Margin="0,0,0,24"
                     MouseLeftButtonDown="ForgotLink_Click">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#00FF41"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <!-- Primary action -->
          <Button x:Name="PrimaryButton" Content="SIGN IN" Style="{StaticResource PrimaryBtn}"
                  Click="PrimaryButton_Click" Margin="0,0,0,10"/>

          <!-- Divider -->
          <Grid Margin="0,4,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Height="1" Background="#1a1a1a" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="  or  " FontSize="11" Foreground="#2a2a2a" Margin="4,0"/>
            <Border Grid.Column="2" Height="1" Background="#1a1a1a" VerticalAlignment="Center"/>
          </Grid>

          <!-- Google -->
          <Button x:Name="GoogleButton" Style="{StaticResource GhostBtn}"
                  Click="GoogleButton_Click" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="G" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#888" Margin="0,0,8,0"/>
              <TextBlock Text="Continue with Google" FontSize="12" Foreground="#888"/>
            </StackPanel>
          </Button>

          <!-- Toggle -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock x:Name="TogglePrompt" Text="Don't have an account?"
                       FontSize="12" Foreground="#444" Margin="0,0,6,0"/>
            <TextBlock x:Name="ToggleLink" Text="Create one"
                       FontSize="12" Foreground="#00FF41" Cursor="Hand"
                       MouseLeftButtonDown="ToggleLink_Click">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="TextDecorations" Value="Underline"/>
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </StackPanel>

          <!-- Buy link -->
          <TextBlock HorizontalAlignment="Center" FontSize="11">
            <Run Text="Need a license? " Foreground="#333"/>
            <Hyperlink NavigateUri="https://vedion.cloud/shop" RequestNavigate="Hyperlink_RequestNavigate"
                       Foreground="#555" TextDecorations="None">
              vedion.cloud/shop
            </Hyperlink>
          </TextBlock>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
