<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VedionScreenShare.Windows.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vedion Screen Share"
    Width="420" Height="580"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#0a0a0a"
    Foreground="#f0f0f0"
    FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="Foreground" Value="#f0f0f0"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00FF41"/>
        </Style>
        <Style x:Key="PasswordInput" TargetType="PasswordBox">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="Foreground" Value="#f0f0f0"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#00FF41"/>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00cc33"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2a2a2a"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#00FF41"/>
                                <Setter Property="Foreground" Value="#00FF41"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="40,40,40,0">
            <TextBlock Text="VEDION" FontFamily="Consolas" FontSize="11" Foreground="#00FF41" LetterSpacing="4" Margin="0,0,0,8"/>
            <TextBlock x:Name="TitleLabel" Text="Sign in" FontSize="26" FontWeight="Bold" Foreground="#f0f0f0" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubLabel" Text="Access your Vedion Screen Share license." FontSize="12" Foreground="#555"/>
        </StackPanel>

        <!-- Footer toggle -->
        <StackPanel DockPanel.Dock="Bottom" Margin="40,0,40,30" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock x:Name="TogglePrompt" Text="Don't have an account?" FontSize="12" Foreground="#555" Margin="0,0,6,0"/>
            <TextBlock x:Name="ToggleLink" Text="Create one" FontSize="12" Foreground="#00FF41" Cursor="Hand" MouseLeftButtonDown="ToggleLink_Click"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="40,24,40,0">
            <StackPanel>

                <!-- Display name (sign-up only) -->
                <StackPanel x:Name="NamePanel" Visibility="Collapsed" Margin="0,0,0,16">
                    <TextBlock Text="DISPLAY NAME" Style="{StaticResource Label}"/>
                    <TextBox x:Name="NameInput" Style="{StaticResource Input}" Text=""/>
                </StackPanel>

                <!-- Email -->
                <TextBlock Text="EMAIL" Style="{StaticResource Label}"/>
                <TextBox x:Name="EmailInput" Style="{StaticResource Input}" Margin="0,0,0,16"/>

                <!-- Password -->
                <TextBlock Text="PASSWORD" Style="{StaticResource Label}"/>
                <PasswordBox x:Name="PasswordInput" Style="{StaticResource PasswordInput}" Margin="0,0,0,8" KeyDown="PasswordInput_KeyDown"/>

                <!-- Forgot password (sign-in only) -->
                <TextBlock x:Name="ForgotLink" Text="Forgot password?" FontSize="11" Foreground="#555" Cursor="Hand"
                           HorizontalAlignment="Right" Margin="0,0,0,20" MouseLeftButtonDown="ForgotLink_Click"/>

                <!-- Status message -->
                <TextBlock x:Name="StatusLabel" Text="" FontSize="12" Foreground="#f87171" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Primary action -->
                <Button x:Name="PrimaryButton" Content="SIGN IN" Style="{StaticResource PrimaryBtn}" Click="PrimaryButton_Click" Margin="0,0,0,12"/>

                <!-- Google -->
                <Button x:Name="GoogleButton" Content="Continue with Google" Style="{StaticResource SecondaryBtn}" Click="GoogleButton_Click" Margin="0,0,0,0"/>

                <!-- Divider -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="1" Background="#1a1a1a" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="  or  " FontSize="11" Foreground="#333" Margin="4,0"/>
                    <Border Grid.Column="2" Height="1" Background="#1a1a1a" VerticalAlignment="Center"/>
                </Grid>

                <!-- Purchase link -->
                <TextBlock Margin="0,16,0,0" TextAlignment="Center">
                    <Run Text="Need a license? " Foreground="#555" FontSize="12"/>
                    <Hyperlink NavigateUri="https://vedion.cloud/shop" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#00FF41" FontSize="12">
                        Buy at vedion.cloud/shop
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
