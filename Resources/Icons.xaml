<!-- Vector icon library — no emojis, all code-drawn WPF Path geometries -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── GEOMETRY DEFINITIONS ────────────────────────────────────────── -->

  <!-- Screen / Capture: monitor outline with scan line -->
  <StreamGeometry x:Key="ScreenGeo">
    M 1,1 L 15,1 L 15,11 L 1,11 Z
    M 5,11 L 5,13 L 11,13
    M 3,13 L 13,13
    M 4,7 L 12,7
  </StreamGeometry>

  <!-- Send / Snapshot: right-pointing arrow -->
  <StreamGeometry x:Key="SendGeo">
    M 1,8 L 15,1 L 11,15 L 8,9 Z
  </StreamGeometry>

  <!-- AI / Neural: three nodes with connecting lines -->
  <StreamGeometry x:Key="NeuralGeo">
    M 8,1 A 1.5,1.5 0 1 1 8,4 A 1.5,1.5 0 1 1 8,1
    M 2,11 A 1.5,1.5 0 1 1 2,14 A 1.5,1.5 0 1 1 2,11
    M 14,11 A 1.5,1.5 0 1 1 14,14 A 1.5,1.5 0 1 1 14,11
    M 8,4 L 2,11 M 8,4 L 14,11 M 2,12 L 14,12
  </StreamGeometry>

  <!-- Check: tick mark -->
  <StreamGeometry x:Key="CheckGeo">
    M 2,9 L 6,13 L 14,3
  </StreamGeometry>

  <!-- Close: X -->
  <StreamGeometry x:Key="CloseGeo">
    M 3,3 L 13,13 M 13,3 L 3,13
  </StreamGeometry>

  <!-- Minus: minimize dash -->
  <StreamGeometry x:Key="MinusGeo">
    M 3,8 L 13,8
  </StreamGeometry>

  <!-- Region / Selection: corner brackets -->
  <StreamGeometry x:Key="RegionGeo">
    M 1,5 L 1,1 L 5,1
    M 11,1 L 15,1 L 15,5
    M 1,11 L 1,15 L 5,15
    M 11,15 L 15,15 L 15,11
  </StreamGeometry>

  <!-- Reset / Refresh: circular arrow -->
  <StreamGeometry x:Key="ResetGeo">
    M 12,4 A 5,5 0 1 0 13,9
    M 13,9 L 13,5 L 9,5
  </StreamGeometry>

  <!-- Webhook / Link: chain link -->
  <StreamGeometry x:Key="LinkGeo">
    M 5,9 A 3,3 0 0 1 5,3 L 7,3 A 3,3 0 0 1 7,9 M 9,7 A 3,3 0 0 1 9,13 L 11,13 A 3,3 0 0 1 11,7
    M 7,6 L 9,6 M 7,10 L 9,10
  </StreamGeometry>

  <!-- Key / License: key shape -->
  <StreamGeometry x:Key="KeyGeo">
    M 3,8 A 3.5,3.5 0 1 1 3,15 A 3.5,3.5 0 1 1 3,8
    M 6.5,10 L 15,10
    M 13,10 L 13,13
    M 11,10 L 11,12
  </StreamGeometry>

  <!-- Settings / Gear: hexagon cog -->
  <StreamGeometry x:Key="GearGeo">
    M 8,5 A 3,3 0 1 1 8,11 A 3,3 0 1 1 8,5
    M 8,1 L 8,3 M 8,13 L 8,15
    M 1,8 L 3,8 M 13,8 L 15,8
    M 3,3 L 4.5,4.5 M 11.5,11.5 L 13,13
    M 13,3 L 11.5,4.5 M 4.5,11.5 L 3,13
  </StreamGeometry>

  <!-- User / Account: head + shoulders -->
  <StreamGeometry x:Key="UserGeo">
    M 8,1 A 3,3 0 1 1 8,7 A 3,3 0 1 1 8,1
    M 1,15 A 7,7 0 0 1 15,15
  </StreamGeometry>

  <!-- Discord wave: three stacked arcs (stylized) -->
  <StreamGeometry x:Key="DiscordGeo">
    M 3,11 C 3,6 13,6 13,11
    M 5,13 C 5,9 11,9 11,13
    M 1,9 C 1,3 15,3 15,9
  </StreamGeometry>

  <!-- Hotkey: keyboard key outline -->
  <StreamGeometry x:Key="HotkeyGeo">
    M 2,4 L 14,4 L 14,12 L 2,12 Z
    M 5,4 L 5,12 M 11,4 L 11,12
    M 2,8 L 14,8
  </StreamGeometry>

  <!-- Signal / Status dot ring -->
  <StreamGeometry x:Key="SignalGeo">
    M 8,6 A 2,2 0 1 1 8,10 A 2,2 0 1 1 8,6
    M 4,4 A 5.66,5.66 0 0 0 4,12
    M 12,4 A 5.66,5.66 0 0 1 12,12
  </StreamGeometry>

  <!-- ── ICON TEMPLATES ────────────────────────────────────────────────── -->
  <!-- Usage: <ContentControl Style="{StaticResource Icon16}" Content="{StaticResource ScreenGeo}"/> -->

  <Style x:Key="Icon12" TargetType="Path">
    <Setter Property="Width"           Value="12"/>
    <Setter Property="Height"          Value="12"/>
    <Setter Property="Stretch"         Value="Uniform"/>
    <Setter Property="StrokeThickness" Value="1.4"/>
    <Setter Property="StrokeLineJoin"  Value="Round"/>
    <Setter Property="StrokeStartLineCap" Value="Round"/>
    <Setter Property="StrokeEndLineCap"   Value="Round"/>
    <Setter Property="Fill"            Value="Transparent"/>
  </Style>

  <Style x:Key="Icon16" TargetType="Path" BasedOn="{StaticResource Icon12}">
    <Setter Property="Width"           Value="16"/>
    <Setter Property="Height"          Value="16"/>
    <Setter Property="StrokeThickness" Value="1.5"/>
  </Style>

  <Style x:Key="Icon20" TargetType="Path" BasedOn="{StaticResource Icon12}">
    <Setter Property="Width"           Value="20"/>
    <Setter Property="Height"          Value="20"/>
    <Setter Property="StrokeThickness" Value="1.5"/>
  </Style>

  <Style x:Key="Icon24" TargetType="Path" BasedOn="{StaticResource Icon12}">
    <Setter Property="Width"           Value="24"/>
    <Setter Property="Height"          Value="24"/>
    <Setter Property="StrokeThickness" Value="1.6"/>
  </Style>

  <!-- Filled icon variant (for status dots etc) -->
  <Style x:Key="IconFilled" TargetType="Path">
    <Setter Property="Width"   Value="16"/>
    <Setter Property="Height"  Value="16"/>
    <Setter Property="Stretch" Value="Uniform"/>
    <Setter Property="StrokeThickness" Value="0"/>
  </Style>

</ResourceDictionary>
