<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════
       GEOMETRY LIBRARY — All 16×16 viewbox, WPF mini-language
       No full-circle arcs (degenerate). Circles = two-semicircle arcs.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Screen / Capture: monitor + stand + base -->
  <StreamGeometry x:Key="ScreenGeo">
    M 1,1 L 15,1 L 15,11 L 1,11 Z
    M 5.5,11 L 5.5,13
    M 10.5,11 L 10.5,13
    M 3.5,13 L 12.5,13
  </StreamGeometry>

  <!-- Send / Snapshot: filled arrowhead -->
  <StreamGeometry x:Key="SendGeo">
    M 2,8 L 14,2 L 10.5,14 L 8,9.5 Z
  </StreamGeometry>

  <!-- Neural / AI: three nodes (circles via semicircles) + edges -->
  <StreamGeometry x:Key="NeuralGeo">
    M 8,1 A 1.5,1.5 0 1 0 8,4 A 1.5,1.5 0 1 0 8,1 Z
    M 2.5,10 A 1.5,1.5 0 1 0 2.5,13 A 1.5,1.5 0 1 0 2.5,10 Z
    M 13.5,10 A 1.5,1.5 0 1 0 13.5,13 A 1.5,1.5 0 1 0 13.5,10 Z
    M 8,4 L 2.5,10
    M 8,4 L 13.5,10
    M 2.5,11.5 L 13.5,11.5
  </StreamGeometry>

  <!-- Check: tick -->
  <StreamGeometry x:Key="CheckGeo">
    M 2,8.5 L 6,12.5 L 14,3.5
  </StreamGeometry>

  <!-- Close: X -->
  <StreamGeometry x:Key="CloseGeo">
    M 3.5,3.5 L 12.5,12.5
    M 12.5,3.5 L 3.5,12.5
  </StreamGeometry>

  <!-- Minus: dash (minimize) -->
  <StreamGeometry x:Key="MinusGeo">
    M 3.5,8 L 12.5,8
  </StreamGeometry>

  <!-- Region / Selection: four corner brackets -->
  <StreamGeometry x:Key="RegionGeo">
    M 1,5.5 L 1,1 L 5.5,1
    M 10.5,1 L 15,1 L 15,5.5
    M 1,10.5 L 1,15 L 5.5,15
    M 10.5,15 L 15,15 L 15,10.5
  </StreamGeometry>

  <!-- Reset / Refresh: open arc + arrowhead -->
  <StreamGeometry x:Key="ResetGeo">
    M 13,8 A 5,5 0 1 0 10.5,12.5
    M 10.5,12.5 L 10.5,15 L 13.5,12.5 Z
  </StreamGeometry>

  <!-- Link / Webhook: two chain ovals -->
  <StreamGeometry x:Key="LinkGeo">
    M 4,6 A 2.5,2.5 0 0 1 4,11 L 6,11 A 2.5,2.5 0 0 0 6,6 Z
    M 10,5 A 2.5,2.5 0 0 1 10,10 L 12,10 A 2.5,2.5 0 0 0 12,5 Z
    M 6,8.5 L 10,8.5
  </StreamGeometry>

  <!-- Key / License -->
  <StreamGeometry x:Key="KeyGeo">
    M 4,7 A 3,3 0 1 0 4,13 A 3,3 0 1 0 4,7 Z
    M 7,10 L 15,10
    M 13,10 L 13,13
    M 11,10 L 11,12
  </StreamGeometry>

  <!-- Settings / Gear: circle + 4 tick marks -->
  <StreamGeometry x:Key="GearGeo">
    M 8,5 A 3,3 0 1 0 8,11 A 3,3 0 1 0 8,5 Z
    M 8,1 L 8,3.5
    M 8,12.5 L 8,15
    M 1,8 L 3.5,8
    M 12.5,8 L 15,8
    M 3,3 L 4.8,4.8
    M 11.2,11.2 L 13,13
    M 13,3 L 11.2,4.8
    M 4.8,11.2 L 3,13
  </StreamGeometry>

  <!-- User / Account: head circle + arc shoulders -->
  <StreamGeometry x:Key="UserGeo">
    M 8,2 A 3,3 0 1 0 8,8 A 3,3 0 1 0 8,2 Z
    M 2,15 A 6,6 0 0 1 14,15
  </StreamGeometry>

  <!-- Discord-style: three concentric arcs -->
  <StreamGeometry x:Key="DiscordGeo">
    M 3,11 C 3,6.5 13,6.5 13,11
    M 5,13 C 5,9.5 11,9.5 11,13
    M 1,9 C 1,3 15,3 15,9
  </StreamGeometry>

  <!-- Hotkey: keyboard outline + two keys -->
  <StreamGeometry x:Key="HotkeyGeo">
    M 2,4 L 14,4 L 14,12 L 2,12 Z
    M 5,4 L 5,12
    M 11,4 L 11,12
    M 2,8 L 14,8
  </StreamGeometry>

  <!-- Signal: dot + two arcs (status indicator) -->
  <StreamGeometry x:Key="SignalGeo">
    M 8,6.5 A 1.5,1.5 0 1 0 8,9.5 A 1.5,1.5 0 1 0 8,6.5 Z
    M 4.5,4.5 A 5,5 0 0 0 4.5,11.5
    M 11.5,4.5 A 5,5 0 0 1 11.5,11.5
  </StreamGeometry>

  <!-- Play: right-pointing triangle -->
  <StreamGeometry x:Key="PlayGeo">
    M 4,2 L 14,8 L 4,14 Z
  </StreamGeometry>

  <!-- Stop: filled square -->
  <StreamGeometry x:Key="StopGeo">
    M 3,3 L 13,3 L 13,13 L 3,13 Z
  </StreamGeometry>

  <!-- ═══════════════════════════════════════════════════════════════════
       SIZE STYLES — apply to Path elements
       Usage: <Path Data="{StaticResource SendGeo}" Style="{StaticResource Icon16}" Stroke="#00FF41"/>
       ═══════════════════════════════════════════════════════════════════ -->

  <Style x:Key="Icon12" TargetType="Path">
    <Setter Property="Width"                 Value="12"/>
    <Setter Property="Height"                Value="12"/>
    <Setter Property="Stretch"               Value="Uniform"/>
    <Setter Property="StrokeThickness"       Value="1.4"/>
    <Setter Property="StrokeLineJoin"        Value="Round"/>
    <Setter Property="StrokeStartLineCap"    Value="Round"/>
    <Setter Property="StrokeEndLineCap"      Value="Round"/>
    <Setter Property="Fill"                  Value="Transparent"/>
    <Setter Property="SnapsToDevicePixels"   Value="True"/>
  </Style>

  <Style x:Key="Icon16" TargetType="Path" BasedOn="{StaticResource Icon12}">
    <Setter Property="Width"           Value="16"/>
    <Setter Property="Height"          Value="16"/>
    <Setter Property="StrokeThickness" Value="1.5"/>
  </Style>

  <Style x:Key="Icon20" TargetType="Path" BasedOn="{StaticResource Icon12}">
    <Setter Property="Width"           Value="20"/>
    <Setter Property="Height"          Value="20"/>
    <Setter Property="StrokeThickness" Value="1.5"/>
  </Style>

  <Style x:Key="Icon24" TargetType="Path" BasedOn="{StaticResource Icon12}">
    <Setter Property="Width"           Value="24"/>
    <Setter Property="Height"          Value="24"/>
    <Setter Property="StrokeThickness" Value="1.6"/>
  </Style>

  <!-- Filled variant: no stroke, uses Fill -->
  <Style x:Key="IconFilled16" TargetType="Path">
    <Setter Property="Width"               Value="16"/>
    <Setter Property="Height"              Value="16"/>
    <Setter Property="Stretch"             Value="Uniform"/>
    <Setter Property="StrokeThickness"     Value="0"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
  </Style>

</ResourceDictionary>
