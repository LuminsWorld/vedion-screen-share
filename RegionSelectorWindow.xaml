<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VedionScreenShare.RegionSelectorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="#55000000"
    Topmost="True"
    WindowState="Maximized"
    Cursor="Cross"
    Title="Select Region">

    <Canvas x:Name="MainCanvas"
            MouseLeftButtonDown="Canvas_MouseDown"
            MouseMove="Canvas_MouseMove"
            MouseLeftButtonUp="Canvas_MouseUp">

        <!-- Instruction text -->
        <TextBlock x:Name="HintText"
                   Canvas.Left="20" Canvas.Top="20"
                   Text="Click and drag to select the screen region to capture. Press Escape to cancel."
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   Effect="{DynamicResource TextShadow}"/>

        <!-- Selection rectangle -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="#00BFFF"
                   StrokeThickness="2"
                   Fill="#3300BFFF"
                   Visibility="Collapsed"/>

        <!-- Size label -->
        <TextBlock x:Name="SizeLabel"
                   Foreground="#00BFFF"
                   FontSize="13"
                   FontWeight="Bold"
                   Visibility="Collapsed"/>
    </Canvas>
</Window>
